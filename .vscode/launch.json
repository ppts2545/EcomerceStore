{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Launch Spring Boot App",
            "request": "launch",
            "mainClass": "com.example.E_commerceStore.WebApp.Application",
            "projectName": "E-commerceStore.WebApp",
            "args": "",
            "envFile": "${workspaceFolder}/backend/.env",
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "type": "java",
            "name": "Debug Spring Boot App",
            "request": "launch",
            "mainClass": "com.example.E_commerceStore.WebApp.Application",
            "projectName": "E-commerceStore.WebApp",
            "args": "",
            "envFile": "${workspaceFolder}/backend/.env",
            "cwd": "${workspaceFolder}/backend",
            "vmArgs": "-Dspring.profiles.active=dev"
        },
        {
            "name": "Launch Chrome for Frontend",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend/src",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
